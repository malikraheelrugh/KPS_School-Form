# Backend Configuration

# Server port (default: 5000)
PORT=5000

# Frontend URL for CORS (optional, default: allow all origins)
FRONTEND_URL=http://localhost:5173

# Database Configuration (required for production/deployment)
# Uncomment and fill in one of these options:

# PostgreSQL
# DATABASE_URL=postgresql://user:password@host:port/database

# MongoDB
# MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/database

# For local development with JSON file storage (not recommended for production):
# Leave database configs empty and the app will use students.json
